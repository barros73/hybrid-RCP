{
  "name": "hybrid-rcp",
  "displayName": "Hybrid RCP",
  "version": "0.6.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Programming Languages",
    "Visualization",
    "Data Science"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "bin": {
    "hybrid-rcp": "./dist/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "hybrid-rcp.analyzeProject",
        "title": "Hybrid RCP: Analyze Project (Graph & Conflicts)"
      },
      {
        "command": "hybrid-rcp.createBlock",
        "title": "Hybrid RCP: Create New Block"
      },
      {
        "command": "hybrid-rcp.analyzeLock",
        "title": "Hybrid RCP: Analyze Lock File (Dependencies)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hybrid-rcp.createBlock",
          "group": "hybrid-rcp"
        },
        {
          "command": "hybrid-rcp.analyzeProject",
          "group": "hybrid-rcp"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./test-parser.js"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}