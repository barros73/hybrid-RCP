{
  "name": "hybrid-rst",
  "displayName": "Hybrid RST",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:hybrid-rst.parseLib"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hybrid-rst.analyzeProject",
        "title": "Hybrid RST: Analyze Project (Graph & Conflicts)"
      },
      {
        "command": "hybrid-rst.createBlock",
        "title": "Hybrid RST: Create New Block"
      },
      {
        "command": "hybrid-rst.analyzeLock",
        "title": "Hybrid RST: Analyze Lock File (Dependencies)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hybrid-rst.createBlock",
          "group": "hybrid-rst"
        },
        {
          "command": "hybrid-rst.analyzeProject",
          "group": "hybrid-rst"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./test-parser.js"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  }
}
